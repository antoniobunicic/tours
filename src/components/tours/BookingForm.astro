---
import type { CollectionEntry } from 'astro:content';
import type { AvailableSlot } from '@lib/availability';

interface Props {
  tour: CollectionEntry<'tours'>;
  slots: AvailableSlot[];
  /** True if the ICS fetch failed — fall back to a free date input */
  slotsError: boolean;
}

const { tour, slots, slotsError } = Astro.props;
const { slug, data } = tour;
const { price, maxGroupSize, title } = data;

const paypalClientId = import.meta.env.PUBLIC_PAYPAL_CLIENT_ID ?? '';

const useFreeInput = slotsError;
const noTours = !slotsError && slots.length === 0;

const tomorrow = new Date();
tomorrow.setDate(tomorrow.getDate() + 1);
const minDate = tomorrow.toISOString().split('T')[0];
---

<section id="booking" class="bg-slate-50 py-16">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-display font-bold text-slate-900 mb-2 text-center">Book your spot</h2>
    <p class="text-slate-500 text-center mb-8">Fill in your details, then pay securely via PayPal or credit/debit card.</p>

    {noTours ? (
      <div class="bg-white rounded-[var(--radius-card)] shadow-md border border-slate-100 p-8 text-center">
        <p class="text-slate-600 mb-4">
          No tours are currently scheduled for the next 90 days.
        </p>
        <p class="text-slate-500 text-sm">
          Contact us at <a href="mailto:hello@splittours.com" class="text-primary-600 hover:underline">hello@splittours.com</a> and we'll arrange something for you.
        </p>
      </div>
    ) : (
      <form
        id="booking-form"
        novalidate
        class="bg-white rounded-[var(--radius-card)] shadow-md border border-slate-100 p-6 sm:p-8 space-y-5"
      >
        <input type="hidden" name="tourSlug" value={slug} />

        <!-- Name -->
        <div>
          <label for="name" class="block text-sm font-medium text-slate-700 mb-1.5">
            Full name <span class="text-red-500" aria-hidden="true">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            placeholder="Jane Smith"
            class="w-full px-4 py-2.5 rounded-lg border border-slate-200 text-slate-900 placeholder:text-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 transition-colors outline-none text-sm"
          />
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">
            Email address <span class="text-red-500" aria-hidden="true">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            placeholder="jane@example.com"
            class="w-full px-4 py-2.5 rounded-lg border border-slate-200 text-slate-900 placeholder:text-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 transition-colors outline-none text-sm"
          />
          <p class="mt-1 text-xs text-slate-400">PayPal will send a payment receipt here.</p>
        </div>

        <!-- Date + People -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="date" class="block text-sm font-medium text-slate-700 mb-1.5">
              Tour date <span class="text-red-500" aria-hidden="true">*</span>
            </label>

            {useFreeInput ? (
              <input
                type="date"
                id="date"
                name="date"
                required
                min={minDate}
                class="w-full px-4 py-2.5 rounded-lg border border-slate-200 text-slate-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 transition-colors outline-none text-sm"
              />
            ) : (
              <select
                id="date"
                name="date"
                required
                class="w-full px-4 py-2.5 rounded-lg border border-slate-200 text-slate-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 transition-colors outline-none text-sm bg-white"
              >
                <option value="">Select a date…</option>
                {slots.map(({ value, label }) => (
                  <option value={value}>{label}</option>
                ))}
              </select>
            )}
          </div>

          <div>
            <label for="people" class="block text-sm font-medium text-slate-700 mb-1.5">
              Number of people <span class="text-red-500" aria-hidden="true">*</span>
            </label>
            <select
              id="people"
              name="people"
              required
              class="w-full px-4 py-2.5 rounded-lg border border-slate-200 text-slate-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 transition-colors outline-none text-sm bg-white"
            >
              {Array.from({ length: maxGroupSize }, (_, i) => i + 1).map((n) => (
                <option value={n}>{n} {n === 1 ? 'person' : 'people'}</option>
              ))}
            </select>
          </div>
        </div>

        <!-- Price preview -->
        <div class="rounded-lg bg-primary-50 border border-primary-100 px-4 py-3 flex justify-between items-center text-sm">
          <span class="text-slate-600">Total</span>
          <span id="price-preview" class="font-bold text-primary-700 text-base">€{price}</span>
        </div>

        <!-- Error message -->
        <p id="form-error" role="alert" class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-4 py-3"></p>

        <!-- PayPal button renders here -->
        <div id="paypal-button-container" class="min-h-[50px]"></div>

        <p class="text-xs text-slate-400 text-center">
          No PayPal account required — pay by credit or debit card as a guest.
        </p>
      </form>
    )}
  </div>
</section>

<script is:inline define:vars={{ price, title, paypalClientId }}>
  const peopleSelect = document.getElementById('people');
  const pricePreview = document.getElementById('price-preview');
  const errorBox = document.getElementById('form-error');

  peopleSelect?.addEventListener('change', () => {
    const n = parseInt(peopleSelect.value, 10);
    if (pricePreview) pricePreview.textContent = `€${price * n}`;
  });

  function showError(message) {
    if (errorBox) {
      errorBox.textContent = message;
      errorBox.classList.remove('hidden');
    }
  }

  function hideError() {
    if (errorBox) errorBox.classList.add('hidden');
  }

  const sdkScript = document.createElement('script');
  sdkScript.src = `https://www.paypal.com/sdk/js?client-id=${paypalClientId}&currency=EUR&locale=en_US`;
  sdkScript.addEventListener('load', initPayPal);
  sdkScript.addEventListener('error', () => showError('Could not load payment provider. Please try again later.'));
  document.head.appendChild(sdkScript);

  function initPayPal() {
    paypal.Buttons({
      style: { color: 'blue', shape: 'pill', label: 'pay', height: 48 },
      createOrder: (_data, actions) => {
        hideError();

        const form = document.getElementById('booking-form');
        if (!form.checkValidity()) {
          form.reportValidity();
          return Promise.reject(new Error('Please fill in all required fields.'));
        }

        const people = parseInt(peopleSelect.value, 10);
        const date = document.getElementById('date').value;
        const name = document.getElementById('name').value;
        const total = (price * people).toFixed(2);

        return actions.order.create({
          purchase_units: [{
            description: `${title} | ${people} ${people === 1 ? 'person' : 'people'} | ${date} | ${name}`,
            amount: { value: total, currency_code: 'EUR' },
          }],
        });
      },
      onApprove: (_data, actions) => {
        return actions.order.capture().then(() => {
          window.location.href = '/booking/success';
        });
      },
      onError: (err) => {
        console.error('[PayPal]', err);
        showError('Payment could not be completed. Please try again or contact us directly.');
      },
    }).render('#paypal-button-container');
  }
</script>
