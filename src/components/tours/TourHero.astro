---
import type { CollectionEntry } from 'astro:content';
import Badge from '@components/ui/Badge.astro';
import Button from '@components/ui/Button.astro';
import Boat from 'phosphor-astro/Boat.astro';
import PersonSimpleWalk from 'phosphor-astro/PersonSimpleWalk.astro';

interface Props {
  tour: CollectionEntry<'tours'>;
}

const { tour } = Astro.props;
const { data } = tour;
const { title, description, price, duration, maxGroupSize, includes, highlights, image, imageAlt, meetingPoint, languages, category } = data;
---

<!-- Hero image -->
<section class="relative h-[55vh] min-h-80 max-h-[600px] overflow-hidden" aria-label="Tour hero">
  <img
    src={image}
    alt={imageAlt}
    width="1600"
    height="900"
    loading="eager"
    fetchpriority="high"
    decoding="async"
    class="w-full h-full object-cover"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-slate-900/70 via-slate-900/20 to-transparent"></div>

  <div class="absolute bottom-0 left-0 right-0 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-8">
    <Badge variant={category === 'boat' ? 'blue' : 'green'} class="mb-3">
      {category === 'boat'
        ? <><Boat width={14} height={14} /> Boat tour</>
        : <><PersonSimpleWalk width={14} height={14} /> Walking tour</>}
    </Badge>
    <h1 class="text-4xl md:text-5xl font-display font-bold text-white drop-shadow-sm">
      {title}
    </h1>
  </div>
</section>

<!-- Details -->
<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
    <!-- Main content -->
    <div class="lg:col-span-2 space-y-10">
      <!-- Overview -->
      <div>
        <p class="text-lg text-slate-600 leading-relaxed">{description}</p>
      </div>

      <!-- Highlights -->
      <div>
        <h2 class="text-2xl font-display font-bold text-slate-900 mb-5">Highlights</h2>
        <ul class="space-y-3">
          {highlights.map((item) => (
            <li class="flex items-start gap-3 text-slate-700">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary-500 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- What's included -->
      <div>
        <h2 class="text-2xl font-display font-bold text-slate-900 mb-5">What's included</h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {includes.map((item) => (
            <li class="flex items-center gap-3 text-slate-700 bg-slate-50 rounded-lg px-4 py-3 text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Booking sidebar -->
    <aside class="lg:col-span-1">
      <!-- Quick info card -->
      <div class="bg-white rounded-[var(--radius-card)] shadow-lg border border-slate-100 p-6 mb-6 sticky top-24">
        <div class="text-3xl font-bold text-slate-900 mb-1">
          €{price} <span class="text-base font-normal text-slate-500">/ person</span>
        </div>
        <p class="text-sm text-slate-500 mb-6">Price includes all listed items. No hidden fees.</p>

        <dl class="space-y-3 text-sm mb-6">
          <div class="flex justify-between">
            <dt class="text-slate-500">Duration</dt>
            <dd class="font-medium text-slate-800">{duration}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-slate-500">Group size</dt>
            <dd class="font-medium text-slate-800">Max {maxGroupSize} people</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-slate-500">Languages</dt>
            <dd class="font-medium text-slate-800">{languages.join(', ')}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-slate-500">Meeting point</dt>
            <dd class="font-medium text-slate-800 text-right max-w-[180px]">{meetingPoint}</dd>
          </div>
        </dl>

        <Button href="#booking" variant="primary" size="lg" class="w-full justify-center">
          Reserve your spot
        </Button>
      </div>
    </aside>
  </div>
</section>
