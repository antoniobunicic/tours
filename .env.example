# PayPal — copy to .env and fill in your Client ID
# Find it in: PayPal Developer Dashboard → Apps & Credentials → your app → Client ID
# Use the Sandbox Client ID for testing, Live Client ID for production.
PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# Google Calendar ICS feed URL (server-side only)
# How to find: Google Calendar → Settings → your calendar → "Secret address in iCal format"
# Format: https://calendar.google.com/calendar/ical/CALENDAR_ID/public/basic.ics
GOOGLE_CALENDAR_ICS_URL=https://calendar.google.com/calendar/ical/your_calendar_id%40group.calendar.google.com/public/basic.ics
